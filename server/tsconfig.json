{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "paths": {
            "sgs3v3-shared": [
                "../shared/src/index.ts"
            ]
        }
    },
    "include": [
        "src/**/*",
        "../shared/src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}